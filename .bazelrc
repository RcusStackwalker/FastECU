common --enable_bzlmod
common --enable_platform_specific_config
build --incompatible_default_to_explicit_init_py

# Disable the built-in C++17 default on Windows to stop the D9025 override warning
# see https://github.com/bazelbuild/rules_cc/issues/591
build --features=-default_cpp_std

build:linux --cxxopt=-std=c++20
build:linux --host_cxxopt=-std=c++20
build:macos --cxxopt=-std=c++20
build:macos --host_cxxopt=-std=c++20
build:windows --cxxopt=/std:c++20
build:windows --host_cxxopt=/std:c++20
build:windows --cxxopt=/Zc:__cplusplus
build:windows --host_cxxopt=/Zc:__cplusplus

# --enable_runfiles defaults to false on Windows (real runfiles trees normally
# need symlinks, which need elevated privilege there), so cc_test/cc_binary
# targets only get a runfiles *manifest* file -- no physical .runfiles
# directory. Runfiles-aware tools (e.g. Python's bootstrap) can resolve data
# deps via that manifest; native code with no such awareness (e.g. Qt's
# plugin loader, which just does a plain directory listing) finds nothing.
# This forces Bazel to materialize the tree via file copies instead (no
# elevated privilege needed), so plain filesystem access sees real files.
build:windows --enable_runfiles
build --features=compiler_param_file
build --action_env=QT_SELECT=qt6
build --action_env=PATH

build:release --compilation_mode=opt
build:release --copt=-DQT_FORCE_ASSERTS

test --test_output=errors
