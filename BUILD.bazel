load("@rules_python//python:defs.bzl", "py_test")
load("//bazel:fastecu_sources.bzl", "APP_COMMON_HDRS", "APP_COMMON_SRCS", "APP_FORMS", "APP_MAIN_SRCS", "APP_MOC_HDRS", "APP_REPS", "APP_RESOURCES", "APP_UNIX_HDRS", "APP_UNIX_SRCS", "APP_WIN_HDRS", "APP_WIN_SRCS")
load("//bazel:qt_remote_objects.bzl", "qt_replica_library")
load("//bazel:qt_targets.bzl", "COMMON_COPTS", "COMMON_INCLUDES", "COMMON_LINKOPTS", "QT_DEPS", "qt_cc_binary", "qt_cc_library", "qt_resource_via_qrc", "qt_ui_basename_libraries")

package(default_visibility = ["//visibility:public"])

exports_files(APP_COMMON_HDRS + APP_MOC_HDRS + APP_REPS + APP_RESOURCES)

APP_COMMON_MOC_HDRS = [
    h
    for h in APP_MOC_HDRS
    if h not in APP_UNIX_HDRS and h not in APP_WIN_HDRS
]

APP_UNIX_MOC_HDRS = [h for h in APP_UNIX_HDRS if h in APP_MOC_HDRS]

APP_WIN_MOC_HDRS = [h for h in APP_WIN_HDRS if h in APP_MOC_HDRS]

APP_UNIX_NORMAL_HDRS = [h for h in APP_UNIX_HDRS if h not in APP_UNIX_MOC_HDRS]

APP_WIN_NORMAL_HDRS = [h for h in APP_WIN_HDRS if h not in APP_WIN_MOC_HDRS]

qt_ui_basename_libraries(
    name = "fastecu_ui_libraries",
    forms = APP_FORMS,
    deps = ["@rules_qt//:qt_widgets"],
)

qt_replica_library(
    name = "fastecu_replicas",
    reps = APP_REPS,
    deps = QT_DEPS,
)

qt_resource_via_qrc(
    name = "config_resource",
    files = glob(["config/*"]),
    qrc_file = "config.qrc",
    deps = ["@rules_qt//:qt_core"],
)

qt_resource_via_qrc(
    name = "font_resource",
    files = glob(["fonts/*"]),
    qrc_file = "fonts.qrc",
    deps = ["@rules_qt//:qt_core"],
)

qt_resource_via_qrc(
    name = "hexedit_resource",
    files = glob([
        "hexedit/images/*",
        "hexedit/translations/*.qm",
    ]),
    qrc_file = "hexedit/qhexedit.qrc",
    deps = ["@rules_qt//:qt_core"],
)

qt_resource_via_qrc(
    name = "icons_resource",
    files = glob(["icons/*"]),
    qrc_file = "icons.qrc",
    deps = ["@rules_qt//:qt_core"],
)

qt_resource_via_qrc(
    name = "images_resource",
    files = glob(["images/*"]),
    qrc_file = "images.qrc",
    deps = ["@rules_qt//:qt_core"],
)

qt_resource_via_qrc(
    name = "kernels_resource",
    files = glob(["kernels/*"]),
    qrc_file = "kernels.qrc",
    deps = ["@rules_qt//:qt_core"],
)

qt_cc_library(
    name = "fastecu_core_common",
    srcs = APP_COMMON_SRCS,
    hdrs = APP_COMMON_MOC_HDRS,
    copts = COMMON_COPTS,
    includes = COMMON_INCLUDES,
    linkopts = COMMON_LINKOPTS + select({
        "@platforms//os:windows": [
            "-lopengl32",
            "-lsetupapi",
        ],
        "//conditions:default": [],
    }),
    normal_hdrs = APP_COMMON_HDRS + select({
        "@platforms//os:windows": APP_WIN_HDRS,
        "//conditions:default": APP_UNIX_HDRS,
    }),
    deps = QT_DEPS + [
        ":config_resource",
        ":fastecu_replicas",
        ":font_resource",
        ":hexedit_resource",
        ":icons_resource",
        ":images_resource",
        ":kernels_resource",
    ] + [
        ":ui_" + ui.split("/")[-1].rsplit(".", 1)[0]
        for ui in APP_FORMS
    ] + ["@openssl"],
)

qt_cc_library(
    name = "fastecu_platform_unix",
    srcs = APP_UNIX_SRCS,
    hdrs = APP_UNIX_MOC_HDRS,
    copts = COMMON_COPTS,
    includes = COMMON_INCLUDES,
    normal_hdrs = APP_UNIX_NORMAL_HDRS,
    target_compatible_with = select({
        "@platforms//os:windows": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    deps = QT_DEPS,
)

qt_cc_library(
    name = "fastecu_platform_windows",
    srcs = APP_WIN_SRCS,
    hdrs = APP_WIN_MOC_HDRS,
    copts = COMMON_COPTS,
    includes = COMMON_INCLUDES,
    normal_hdrs = APP_WIN_NORMAL_HDRS,
    target_compatible_with = select({
        "@platforms//os:windows": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }),
    deps = QT_DEPS,
)

qt_cc_binary(
    name = "fastecu",
    srcs = APP_MAIN_SRCS,
    copts = COMMON_COPTS,
    linkopts = COMMON_LINKOPTS,
    deps = [
        ":fastecu_core_common",
    ] + select({
        "@platforms//os:windows": [":fastecu_platform_windows"],
        "//conditions:default": [":fastecu_platform_unix"],
    }),
)

py_test(
    name = "qmake_bazel_sync",
    srcs = ["scripts/check-bazel-qmake-sync.py"],
    data = [
        "FastECU.pro",
        "protocol/protocol.pri",
        "//bazel:fastecu_sources.bzl",
        "//tests:pro_files",
        "//tests/force_asserts:pro_files",
    ],
    main = "scripts/check-bazel-qmake-sync.py",
)

py_test(
    name = "bazel_openssl_wiring",
    srcs = ["scripts/check-bazel-openssl.py"],
    data = [
        ".github/workflows/pr.yml",
        "BUILD.bazel",
        "MODULE.bazel",
    ],
    main = "scripts/check-bazel-openssl.py",
)

py_test(
    name = "openpty_includes",
    srcs = ["scripts/check-openpty-includes.py"],
    data = ["//tests:cpp_sources"],
    main = "scripts/check-openpty-includes.py",
)

py_test(
    name = "windows_preprocessor_guards",
    srcs = ["scripts/check-windows-preprocessor-guards.py"],
    data = [
        "file_actions.h",
        "serial_port/serial_port_actions_direct.h",
    ],
    main = "scripts/check-windows-preprocessor-guards.py",
)

py_test(
    name = "clang_tidy_report",
    srcs = ["scripts/clang_tidy_report.py"],
    args = ["bazel/fastecu_sources.bzl"],
    data = [
        ".clang-tidy",
        "//bazel:fastecu_sources.bzl",
    ],
    main = "scripts/clang_tidy_report.py",
    tags = [
        "clang-tidy",
        "manual",
    ],
)
